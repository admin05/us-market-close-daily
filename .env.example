# Bark: 支持 bare key 或完整 endpoint，例如：
# BARK=your_bark_key
# BARK=https://api.day.app/your_bark_key
BARK=

# 可选：覆盖报告日期，格式 YYYY-MM-DD。默认使用当前日期。
REPORT_DATE=

# 可选：Yahoo Finance 请求超时，单位毫秒。
HTTP_TIMEOUT_MS=15000

# 可选：Bark 推送超时，单位毫秒。默认较短，避免 Arcadia 任务停留在通知阶段。
BARK_TIMEOUT_MS=8000

# 可选：行情并发数。Arcadia 网络较慢时可降到 3-4；默认 6。
MARKET_DATA_CONCURRENCY=6

# 可选：行情备用源。Arcadia 上 Yahoo Finance 可能 403，建议至少配置一个。
FINNHUB_API_KEY=
FMP_API_KEY=

# 可选：报告输出目录。
REPORTS_DIR=reports

# 可选：缓存输出目录。同一天重复运行会复用已成功抓到的行情，节省 API calls。
DATA_DIR=data

# 可选：新闻雷达事件源。默认抓取首页最新事件；也可设为 https://stocks.matraceai.com/?type=overseas
NEWS_SOURCE_URL=https://stocks.matraceai.com/

# 可选：日报中展示的新闻事件数量。
NEWS_LIMIT=8

# 可选：重点公司新闻总数和单个股票最多新闻数。
COMPANY_NEWS_LIMIT=12
COMPANY_NEWS_PER_SYMBOL=2

# 可选：财报日历重点事件数量。
EARNINGS_LIMIT=12

# 可选：设为 1 时跳过新闻抓取，适合 Arcadia 网络无法访问新闻源时使用。
SKIP_NEWS=0

# 可选：Arcadia 若需代理访问外网，Node 请求会读取这些环境变量。
# HTTPS_PROXY=http://127.0.0.1:7890
# HTTP_PROXY=http://127.0.0.1:7890
